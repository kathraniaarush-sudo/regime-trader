# Copy this file to `.env` and fill in your Alpaca credentials.
# The real `.env` is git-ignored and must NEVER be committed or shared.
#
# Get keys from https://alpaca.markets  ->  Paper Trading  ->  API Keys
# Start with PAPER trading. Only switch to a live account after extensive testing.

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Paper endpoint (default). Live endpoint: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Keep "true" for paper trading. Set "false" ONLY for a funded live account.
ALPACA_PAPER=true
